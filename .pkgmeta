package-as: LoadoutLocker
wowi-archive-previous: no

externals:
  Libs/LibStub:
    url: https://repos.wowace.com/wow/libstub/trunk
    tag: 1.0
  Libs/CallbackHandler-1.0:
    url: https://repos.wowace.com/wow/callbackhandler/trunk/CallbackHandler-1.0
    tag: latest
  Libs/LibSharedMedia-3.0:
    url: https://repos.wowace.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
  Libs/LibDFramework-1.0: https://github.com/Tercioo/Details-Framework

ignore:
  - LICENSE
  - LICENSE.*
  - license
  - license.*
  - README.md
  - readme.md
  - CHANGELOG.md
  - changelog.md
  - .github
  - .vscode
  - .luarc.json
  - .luacheckrc

  - Libs/LibSharedMedia-3.0/LibSharedMedia-3.0.toc
  - Libs/LibSharedMedia-3.0/CHANGES.txt

  - Libs/LibDFramework-1.0/LibDFramework-1.0.toc
